# Supabase connection
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# OpenRouter API key (for both chat + embeddings)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# OpenRouter chat model (free-tier friendly)
OPENROUTER_CHAT_MODEL=tencent/hy3:free

# Google Gemini API (legacy — only needed if switching back)
# GEMINI_API_KEY=your-gemini-api-key

# Self-hosted local chat endpoint (hybrid fallback for general questions)
# LOCAL_CHAT_ENDPOINT=http://your-local-endpoint:port/v1
# LOCAL_CHAT_API_KEY=your-api-key
# LOCAL_CHAT_MODEL=auto/best-chat
