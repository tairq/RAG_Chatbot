# Supabase connection
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# OpenRouter API key (for both chat + embeddings)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# OpenRouter chat model (free-tier friendly)
# See https://openrouter.ai/models for available free models
OPENROUTER_CHAT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# OpenRouter embedding model (free-tier friendly)
# Must match the dimension used in pgvector (default: 2048)
OPENROUTER_EMBEDDING_MODEL=nvidia/nemotron-3-embed-1b:free

# OpenRouter base URL (change only if using a proxy/self-hosted router)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter rate-limit setting (requests per minute for free tier)
# OPENROUTER_RPM=10

# Google Gemini API (legacy — only needed if switching back)
# GEMINI_API_KEY=your-gemini-api-key

# Self-hosted local chat endpoint (hybrid fallback for general questions)
# LOCAL_CHAT_ENDPOINT=http://your-local-endpoint:port/v1
# LOCAL_CHAT_API_KEY=your-api-key
# LOCAL_CHAT_MODEL=auto/best-chat
